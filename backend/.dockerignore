# Build output and caches — rebuilt inside the image.
.gradle/
build/
**/build/

# VCS and CI
.git/
.github/

# IDE
.idea/
*.iml
.vscode/

# Secrets and local env (never ship into an image layer)
.env
.env.*
!.env.example

# Model artifacts (large; delivered separately, and *.onnx is gitignored)
**/*.onnx

# Logs and OS cruft
*.log
.DS_Store
Thumbs.db
