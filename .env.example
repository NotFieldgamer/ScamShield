# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# In production these are set in the Render dashboard (Environment tab / the render.yaml
# blueprint), injected as runtime environment variables. Never commit a filled-in .env.

# ===== Database (Postgres + pgvector) =====
# A managed Postgres URL (e.g. Neon or Supabase). Add ?sslmode=require for managed hosts.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/scamshield
SPRING_DATASOURCE_USERNAME=scamshield
SPRING_DATASOURCE_PASSWORD=change-me

# ===== Server =====
# The app binds ${PORT:8080}. Render injects PORT automatically in production — do not set it
# there. Locally, leave this unset to use 8080, or override to run on a different port.
# PORT=8080

# ===== Redis (rate limiting / hot-verdict cache) =====
# Local dev uses host/port. In production (e.g. Upstash), set the full connection URL instead —
# it overrides host/port. Use the rediss:// scheme for TLS. Rate limiting fails open if Redis
# is unreachable, so this is optional.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# SPRING_DATA_REDIS_URL=rediss://default:password@host.upstash.io:6379

# ===== Auth / JWT =====
# Required. HMAC-SHA256 signing key; must be at least 32 bytes. The app refuses to
# start without it. Generate one with:  openssl rand -base64 48
JWT_SECRET=
# Optional overrides (ISO-8601 durations):
# JWT_ACCESS_TTL=PT15M
# REFRESH_TTL=P7D

# ===== CORS =====
# The single browser origin allowed to call the API (your deployed frontend on Vercel).
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ===== Embedding model (MiniLM, ~90MB) =====
# The model is NOT committed. The Docker build downloads it from EMBEDDING_MODEL_URL (a build-time
# variable, e.g. set on Render) into EMBEDDING_MODEL_PATH. At runtime the app reads the model from
# EMBEDDING_MODEL_PATH.
EMBEDDING_MODEL_PATH=/app/models/minilm.onnx
# EMBEDDING_MODEL_URL is build-time only — set it in your build environment, not here.
# EMBEDDING_MODEL_URL=https://example.com/minilm.onnx
